<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.chaturbate.dvr.mapper.RecordingMapper">

    <resultMap id="BaseResultMap" type="com.chaturbate.dvr.entity.Recording">
        <id column="id" property="id"/>
        <result column="channel_id" property="channelId"/>
        <result column="channel_username" property="channelUsername"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="duration_seconds" property="durationSeconds"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_format" property="fileFormat"/>
        <result column="quality" property="quality"/>
        <result column="status" property="status"/>
        <result column="error_message" property="errorMessage"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, channel_id, channel_username, start_time, end_time, duration_seconds,
        file_path, file_size, file_format, quality, status, error_message, created_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM recording
        WHERE id = #{id}
    </select>

    <select id="selectByChannelId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM recording
        WHERE channel_id = #{channelId}
        ORDER BY start_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM recording
        ORDER BY start_time DESC
    </select>

    <select id="selectRecording" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM recording
        WHERE status = 'recording'
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO recording (channel_id, channel_username, start_time, file_path, 
                               file_format, quality, status)
        VALUES (#{channelId}, #{channelUsername}, #{startTime}, #{filePath},
                #{fileFormat}, #{quality}, #{status})
    </insert>

    <update id="updateComplete">
        UPDATE recording
        SET end_time = #{endTime},
            duration_seconds = #{durationSeconds},
            file_size = #{fileSize},
            status = #{status}
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE recording SET status = #{status} WHERE id = #{id}
    </update>

    <update id="updateError">
        UPDATE recording 
        SET error_message = #{errorMessage}, status = 'failed' 
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM recording WHERE id = #{id}
    </delete>

</mapper>
