<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.chaturbate.dvr.mapper.SystemConfigMapper">
    
    <!-- 根据配置键查询 -->
    <select id="selectByKey" resultType="com.chaturbate.dvr.entity.SystemConfig">
        SELECT * FROM system_config WHERE config_key = #{key}
    </select>
    
    <!-- 根据配置键更新值 -->
    <update id="updateByKey">
        UPDATE system_config 
        SET config_value = #{value}, updated_at = NOW() 
        WHERE config_key = #{key}
    </update>
    
    <!-- 插入新配置 -->
    <insert id="insert" parameterType="com.chaturbate.dvr.entity.SystemConfig">
        INSERT INTO system_config (config_key, config_value, description) 
        VALUES (#{configKey}, #{configValue}, #{description})
    </insert>
    
    <!-- 查询所有配置 -->
    <select id="selectAll" resultType="com.chaturbate.dvr.entity.SystemConfig">
        SELECT * FROM system_config ORDER BY id
    </select>
    
    <!-- 根据配置键删除 -->
    <delete id="deleteByKey">
        DELETE FROM system_config WHERE config_key = #{key}
    </delete>
    
</mapper>
