<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.chaturbate.dvr.mapper.ChannelMapper">

    <resultMap id="BaseResultMap" type="com.chaturbate.dvr.entity.Channel">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="display_name" property="displayName"/>
        <result column="is_enabled" property="enabled"/>
        <result column="is_recording" property="recording"/>
        <result column="last_status" property="lastStatus"/>
        <result column="last_check_time" property="lastCheckTime"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, display_name, is_enabled, is_recording, 
        last_status, last_check_time, created_at, updated_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM channel
        WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM channel
        WHERE username = #{username}
    </select>

    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM channel
        WHERE is_enabled = 1
        ORDER BY created_at DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM channel
        ORDER BY created_at DESC
    </select>

    <select id="selectRecording" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM channel
        WHERE is_recording = 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO channel (username, display_name, is_enabled, is_recording, last_status)
        VALUES (#{username}, #{displayName}, #{enabled}, #{recording}, #{lastStatus})
    </insert>

    <update id="update">
        UPDATE channel
        <set>
            <if test="displayName != null">display_name = #{displayName},</if>
            <if test="enabled != null">is_enabled = #{enabled},</if>
            <if test="recording != null">is_recording = #{recording},</if>
            <if test="lastStatus != null">last_status = #{lastStatus},</if>
            last_check_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateRecordingStatus">
        UPDATE channel
        SET is_recording = #{recording},
            last_status = #{lastStatus},
            last_check_time = NOW(),
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM channel WHERE id = #{id}
    </delete>

</mapper>
